{
  "name": "mdv",
  "version": "0.1.0",
  "description": "Markdown プレビューア (Mermaid ER選択 / git差分の可視化対応)",
  "main": "./out/main/index.js",
  "author": "keitahino",
  "license": "MIT",
  "bin": {
    "mdv": "./bin/mdv.js"
  },
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "start": "electron-vite preview",
    "typecheck:node": "tsc --noEmit -p tsconfig.node.json",
    "typecheck:web": "tsc --noEmit -p tsconfig.web.json",
    "typecheck": "npm run typecheck:node && npm run typecheck:web"
  },
  "dependencies": {
    "diff": "^7.0.0",
    "rehype-raw": "^7.0.0",
    "simple-git": "^3.27.0"
  },
  "devDependencies": {
    "@types/diff": "^7.0.2",
    "@types/node": "^22.10.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "electron": "^33.2.0",
    "electron-vite": "^2.3.0",
    "highlight.js": "^11.10.0",
    "mermaid": "~10.9.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-markdown": "^9.0.1",
    "rehype-highlight": "^7.0.1",
    "remark-gfm": "^4.0.0",
    "typescript": "^5.7.2",
    "vite": "^5.4.11"
  }
}
